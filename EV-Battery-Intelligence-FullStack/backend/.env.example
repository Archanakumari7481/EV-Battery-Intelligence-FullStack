# ==============================
# SERVER CONFIG
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# DATABASE (MongoDB)
# ==============================
# Local: mongodb://127.0.0.1:27017/ev_battery_dashboard
# Atlas: mongodb+srv://<user>:<password>@cluster0.mongodb.net/ev_battery_dashboard
MONGO_URI=mongodb://127.0.0.1:27017/ev_battery_dashboard

# ==============================
# JWT AUTH
# ==============================
JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# ==============================
# CORS - your frontend URL(s), comma separated
# ==============================
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ==============================
# TELEMETRY SIMULATION ENGINE
# (mirrors the setInterval logic that used to run in the React frontend)
# ==============================
SIMULATE_TELEMETRY=true
HEALTH_UPDATE_INTERVAL_MS=5000
TEMP_UPDATE_INTERVAL_MS=6000
ALERT_INTERVAL_MS=8000
